{
  "enabled": true,
  "name": "Run Tests After Task",
  "description": "Automatically runs vitest after each spec task is completed to verify tests pass",
  "version": "1",
  "when": {
    "type": "postTaskExecution"
  },
  "then": {
    "type": "runCommand",
    "command": "npx vitest run",
    "timeout": 120
  }
}